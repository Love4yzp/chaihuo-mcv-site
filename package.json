{
  "name": "chaihuo-mcv-site",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm run check && astro build",
    "build:astro": "astro build",
    "check": "pnpm run lint && pnpm run check:content && pnpm run check:astro",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check:astro": "astro check",
    "check:content": "node scripts/validate-site.mjs",
    "harness": "pnpm run check && playwright test",
    "smoke": "playwright test tests/harness/smoke.spec.ts",
    "visual": "playwright test tests/harness/visual.spec.ts",
    "audit:ui": "playwright test tests/harness/ui-audit.spec.ts",
    "preview": "astro preview",
    "start": "node ./dist/server/entry.mjs",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.0",
    "@astrojs/react": "^5.0.4",
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "d3-geo": "^3.1.1",
    "d3-selection": "^3.0.0",
    "d3-transition": "^3.0.1",
    "d3-zoom": "^3.0.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-slick": "0.31.0",
    "slick-carousel": "^1.8.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-transition": "^3.0.9",
    "@types/d3-zoom": "^3.0.8",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.9.1",
    "@types/react-slick": "^0.23.13",
    "dxf-parser": "^1.1.2",
    "playwright": "^1.60.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vite": "^7"
  },
  "simple-git-hooks": {
    "pre-commit": "bash scripts/validate-lockfile.sh"
  }
}

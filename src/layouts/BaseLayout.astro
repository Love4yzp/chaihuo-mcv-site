---
import Navigation from '@/app/components/Navigation';
import Footer from '@/layouts/Footer.astro';
import '@/styles/index.css';
import { ClientRouter } from 'astro:transitions';
import type { Locale } from '@/i18n/index';
import { getAlternateUrl } from '@/i18n/index';
import ui from '@/i18n/ui';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const locale = (Astro.currentLocale ?? 'zh') as Locale;
const dict = ui[locale];

const { title, description = dict['site.description'], ogImage = '/og-default.png' } = Astro.props;
const pathname = Astro.url.pathname;
const canonicalURL = new URL(pathname, Astro.site ?? 'https://mcv.chaihuo.org');

const htmlLang = locale === 'zh' ? 'zh-CN' : 'en';
const ogLocale = locale === 'zh' ? 'zh_CN' : 'en_US';
const siteTitle = `${title} | ${dict['site.name']}`;

const alternate = getAlternateUrl(pathname);
const alternateURL = new URL(alternate.path, Astro.site ?? 'https://mcv.chaihuo.org');
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{siteTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL.href} />

    {/* hreflang tags */}
    <link rel="alternate" hreflang="zh" href={locale === 'zh' ? canonicalURL.href : alternateURL.href} />
    <link rel="alternate" hreflang="en" href={locale === 'en' ? canonicalURL.href : alternateURL.href} />
    <link rel="alternate" hreflang="x-default" href={locale === 'zh' ? canonicalURL.href : alternateURL.href} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={locale === 'zh' ? 'en_US' : 'zh_CN'} />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Microsoft Clarity */}
    <script is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window,document,"clarity","script","wc0b9nadad");
    </script>

    {/* Google Analytics 4 */}
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-27XRD69LSR"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-27XRD69LSR');
    </script>
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-surface text-neutral-900">
    <Navigation client:load pathname={pathname} locale={locale} transition:persist />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>

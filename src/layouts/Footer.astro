---
import logoHorizontalImport from '@/assets/logo-horizontal.png';
import type { Locale } from '@/i18n/index';
import ui from '@/i18n/ui';
import { localePath, t } from '@/i18n/index';

const logoSrc = typeof logoHorizontalImport === 'object' && logoHorizontalImport !== null && 'src' in logoHorizontalImport
  ? (logoHorizontalImport as { src: string }).src
  : logoHorizontalImport as string;

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'zh';
const d = ui[locale];
---

<footer class="py-12 px-6 bg-white border-t border-neutral-300">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-4 gap-8 mb-8">
      <!-- Logo + 描述 -->
      <div class="md:col-span-1">
        <div class="flex items-center mb-4">
          <img src={logoSrc} alt={d['site.name']} class="h-10" />
        </div>
        <p class="text-sm text-neutral-500 leading-relaxed">
          {d['footer.description']}
        </p>
        <div class="flex gap-4 mt-6 text-xs text-neutral-400">
          {d['footer.followUs']}
        </div>
      </div>

      <!-- 项目入口 -->
      <div>
        <h4 class="text-xs uppercase tracking-wider mb-4 text-neutral-700 font-semibold">{d['footer.projectLinks']}</h4>
        <div class="space-y-2 text-sm">
          <a href={localePath('/', locale)} class="block text-neutral-500 hover:text-neutral-900 transition-colors duration-200">{d['nav.home']}</a>
          <a href={localePath('/deconstruct', locale)} class="block text-neutral-500 hover:text-neutral-900 transition-colors duration-200">{d['nav.deconstruct']}</a>
          <a href={localePath('/documentation', locale)} class="block text-neutral-500 hover:text-neutral-900 transition-colors duration-200">{d['nav.documentation']}</a>
          <a href={localePath('/guide', locale)} class="block text-neutral-500 hover:text-neutral-900 transition-colors duration-200">{d['nav.guide']}</a>
        </div>
      </div>

      <!-- 联系我们 -->
      <div>
        <h4 class="text-xs uppercase tracking-wider mb-4 text-neutral-700 font-semibold">{d['footer.contact']}</h4>
        <div class="space-y-3 text-sm text-neutral-500">
          <p class="flex items-start gap-2">
            <svg class="w-4 h-4 text-brand shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>{d['footer.addressSZ']}</span>
          </p>
          <p class="flex items-start gap-2">
            <svg class="w-4 h-4 text-brand shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>{d['footer.addressCD']}</span>
          </p>
          <p class="flex items-start gap-2">
            <svg class="w-4 h-4 text-brand shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <span>business@chaihuo.org</span>
          </p>
          <p class="flex items-start gap-2">
            <svg class="w-4 h-4 text-brand shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>0755 - 36937037</span>
          </p>
        </div>
      </div>

      <!-- 社交渠道 -->
      <div>
        <h4 class="text-xs uppercase tracking-wider mb-4 text-neutral-700 font-semibold">{d['footer.social']}</h4>
        <div class="space-y-2 text-sm text-neutral-400">
          <a
            href="https://www.xiaohongshu.com/user/profile/69523906000000000300d495"
            target="_blank"
            rel="noopener noreferrer"
            class="block text-neutral-500 hover:text-neutral-900 transition-colors duration-200"
          >
            {d['footer.xiaohongshu']}
          </a>
          <p>{d['footer.wechat']}</p>
          <p>{d['footer.weibo']}</p>
          <p>{d['footer.twitter']}</p>
          <p>{d['footer.github']}</p>
        </div>
      </div>
    </div>

    <div class="border-t border-neutral-300 pt-8 text-center text-sm text-neutral-500">
      <p>{d['footer.copyright']}</p>
      <p class="mt-2">{d['footer.license']}</p>
    </div>
  </div>
</footer>

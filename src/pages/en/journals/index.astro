---
export const prerender = true;

import JournalsContent from '@/app/components/JournalsContent';
import { loadLocalizedStops } from '@/features/route-map/stops-loader';
import type { Locale } from '@/i18n/index';
import journalsDict from '@/i18n/journals';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllJournals, localizeJournal } from '@/lib/journals';
import yuqueJournalsData from '@/data/yuque-journals.json';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = journalsDict[locale];

// Stops collection — localized once at page level
const cities = await loadLocalizedStops(locale);

// Fetch all active journals (excluding drafts)
const journalsCollection = await getAllJournals({ includeDrafts: false });

// Map all journals to localized formats
const localizedJournals = journalsCollection.map((entry) => localizeJournal(entry, cities, locale));
---

<BaseLayout title={t['title']} description={t['description']}>
  <JournalsContent
    client:load
    cities={cities}
    journals={localizedJournals}
    yuqueJournals={yuqueJournalsData.journals}
    locale={locale}
    t={t}
  />
</BaseLayout>

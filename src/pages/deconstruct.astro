---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import DeconstructContent from '@/app/components/DeconstructContent';
import { getCollection } from 'astro:content';
import equipmentData from '@/data/equipment.json';
import companionData from '@/data/companion.json';
import type { Locale } from '@/i18n/index';
import { localize } from '@/i18n/index';
import deconstructDict from '@/i18n/deconstruct';

const locale = (Astro.currentLocale ?? 'zh') as Locale;
const t = deconstructDict[locale];

const companion = (() => {
  const loc = localize(companionData, ['name', 'bio'], locale);
  return { name: loc.name, image: loc.image, bio: loc.bio };
})();

const notesCollection = await getCollection('notes');
const notes = notesCollection.map(note => ({
  date: note.data.date,
  title: locale === 'en' && note.data.title_en ? note.data.title_en : note.data.title,
  description: locale === 'en' && note.data.description_en ? note.data.description_en : note.data.description,
  image: note.data.image,
  tags: note.data.tags,
}));

const equipment = equipmentData.map(cat => {
  const locCat = localize(cat, ['title'], locale);
  return {
    icon: locCat.icon,
    title: locCat.title,
    items: locCat.items.map(item => localize(item, ['name', 'spec'], locale)),
  };
});
---

<BaseLayout title={t['title']} description={t['description']}>
  {/* client:only 跳过 SSR，避免 Three.js 在服务端解析导致 ~1.8s 延迟 */}
  <DeconstructContent client:only="react" notes={notes} equipment={equipment} companion={companion} locale={locale} t={t} />
</BaseLayout>
